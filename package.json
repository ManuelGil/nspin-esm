{
	"name": "nspin-esm",
	"version": "1.2.0",
	"description": "Lightweight and efficient ESM spinner package for modern Node.js runtimes",
	"keywords": [
		"cli",
		"console",
		"esm",
		"loader",
		"node",
		"nodejs",
		"spinner",
		"terminal",
		"tty"
	],
	"author": {
		"name": "Manuel Gil",
		"email": "support@imgil.dev",
		"url": "https://imgil.dev/"
	},
	"license": "MIT",
	"funding": {
		"type": "github",
		"url": "https://github.com/sponsors/ManuelGil"
	},
	"homepage": "https://github.com/ManuelGil/nspin-esm",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ManuelGil/nspin-esm.git"
	},
	"bugs": {
		"url": "https://github.com/ManuelGil/nspin-esm/issues"
	},
	"type": "module",
	"packageManager": "pnpm@10.0.0",
	"engines": {
		"node": ">=22.0.0"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"sideEffects": false,
	"files": [
		"dist",
		"README.md",
		"CHANGELOG.md",
		"LICENSE"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"clean": "rm -rf dist",
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"ts-check": "tsc --noEmit",
		"check-exports": "attw --pack --ignore-rules cjs-resolves-to-esm",
		"audit": "pnpm audit",
		"audit:fix": "pnpm audit --fix",
		"deps:update": "pnpm update",
		"deps:update:latest": "pnpm update --latest",
		"pack:check": "pnpm pack",
		"prepare": "pnpm exec husky",
		"release": "release-it",
		"prepublishOnly": "pnpm run validate && cp README.npm.md README.md",
		"postpublish": "git checkout -- README.md",
		"validate": "pnpm run check && pnpm run ts-check && pnpm run test && pnpm run build"
	},
	"devDependencies": {
		"@arethetypeswrong/cli": "^0.18.2",
		"@biomejs/biome": "^2.4.15",
		"@commitlint/cli": "^20.5.3",
		"@commitlint/config-conventional": "^20.5.3",
		"@types/node": "^22.19.18",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"release-it": "^19.2.4",
		"typescript": "^5.9.3",
		"vite": "^8.0.11",
		"vite-plugin-dts": "^5.0.0",
		"vitest": "^3.2.4"
	},
	"lint-staged": {
		"*.{ts,js,json,md}": [
			"biome check --write"
		]
	},
	"release-it": {
		"git": {
			"commitMessage": "chore: :bookmark: release ${version}",
			"tagName": "v${version}",
			"requireCleanWorkingDir": true
		},
		"github": {
			"release": true
		},
		"npm": {
			"publish": false
		},
		"hooks": {
			"before:init": "pnpm run validate",
			"before:release": "pnpm run build"
		}
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"husky"
		]
	}
}
